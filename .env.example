# AI GTM Workflows - Environment Variables
# Copy this file to .env and fill in your API keys

# ============================================
# REQUIRED - Core AI
# ============================================

# Anthropic API key for Claude (powers all workflows)
# Get one at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ============================================
# ENRICHMENT APIs (for contact discovery workflows)
# ============================================

# Primary enrichment API - LinkedIn profile + email discovery
# Used by: 08-contact-discovery, 09-local-enrichment
ENRICHMENT_API_KEY=your_enrichment_api_key_here
ENRICHMENT_API_BASE=https://api.your-enrichment-provider.com/v2

# Email verification API - SMTP-level deliverability checks
# Used by: 08-contact-discovery, 09-local-enrichment
EMAIL_VERIFICATION_API_KEY=your_email_verification_api_key_here

# LinkedIn enrichment API - person lookup by LinkedIn URL or name+domain
# Used by: 08-contact-discovery (fallback source)
LINKEDIN_ENRICHMENT_API_KEY=your_linkedin_enrichment_api_key_here

# Phone enrichment API - phone number discovery
# Used by: 08-contact-discovery (optional)
PHONE_ENRICHMENT_API_KEY=your_phone_enrichment_api_key_here

# ============================================
# EMAIL PLATFORM (for campaign launch workflows)
# ============================================

# Your cold email sending platform API key
# Used by: 10-campaign-launch, 11-performance-analysis
EMAIL_PLATFORM_API_KEY=your_email_platform_api_key_here
EMAIL_PLATFORM_BASE_URL=https://your-email-platform-domain/api

# ============================================
# OPTIONAL - Enhanced research
# ============================================

# Google Maps API key - for local business discovery
# Used by: 09-local-enrichment
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Company database API - for TAM building
# Used by: 02-tam-mapping
COMPANY_DATABASE_API_KEY=your_company_database_api_key_here
